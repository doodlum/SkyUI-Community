{
    "version": 10,
    "cmakeMinimumRequired": {
        "major": 4,
        "minor": 2,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "_base",
            "hidden": true,
            "cacheVariables": {
                "SkyrimSE_PATH": {
                    "type": "PATH",
                    "value": "$env{SkyrimSE_PATH}"
                }
            }
        },
        {
            "name": "debug",
            "displayName": "Debug",
            "description": "Compile scripts and SWFs, deploy directly to MOD_DEBUG_OUTPUT_DIR. No BSA, no ZIP.",
            "inherits": "_base",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": {
                    "type": "STRING",
                    "value": "Debug"
                },
                "MOD_DEBUG_OUTPUT_DIR": {
                    "type": "PATH",
                    "value": "$env{MOD_DEBUG_OUTPUT_DIR}"
                },
                "CMAKE_CONFIGURATION_TYPES": {
                    "type": "STRING",
                    "value": "Debug"
                }
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "description": "Full pipeline: compile -> BSA -> SkyUI_SE-<version>.zip",
            "inherits": "_base",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": {
                    "type": "STRING",
                    "value": "Release"
                },
                "CMAKE_CONFIGURATION_TYPES": {
                    "type": "STRING",
                    "value": "Release"
                }
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Debug",
            "configurePreset": "debug",
            "jobs": 0
        },
        {
            "name": "release",
            "displayName": "Release",
            "configurePreset": "release",
            "jobs": 0
        }
    ]
}